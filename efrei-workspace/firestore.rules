rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is the admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "massilabba06@gmail.com";
    }

    match /projects/{project} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reports/{report} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{setting} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
